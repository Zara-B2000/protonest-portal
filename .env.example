# ─────────────────────────────────────────────────────────────
# Protonest Portal — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# ── App URL (must be public HTTPS in production) ──────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── PayHere ───────────────────────────────────────────────────
# Use sandbox values during development
PAYHERE_MERCHANT_ID=your-payhere-merchant-id
PAYHERE_MERCHANT_SECRET=your-payhere-merchant-secret
# sandbox | live
PAYHERE_ENV=sandbox

# ── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Protonest PCB Assembly

# ── Dialog Ideamart (SMS) ─────────────────────────────────────
IDEAMART_APP_ID=your-ideamart-app-id
IDEAMART_PASSWORD=your-ideamart-password
IDEAMART_SENDER_ID=PROTONEST
# Set to "true" to enable SMS; "false" to stub (log only)
SMS_ENABLED=false

# ── Admin ─────────────────────────────────────────────────────
# Comma-separated list of admin email addresses
# These users get the admin role assigned automatically on first login
ADMIN_EMAILS=admin@protonest.lk

# ── File Storage ──────────────────────────────────────────────
# Supabase storage bucket name for order files (must be private)
STORAGE_BUCKET=order-files
# Signed URL expiry in seconds (default: 3600 = 1 hour)
SIGNED_URL_EXPIRY=3600

# ── Shipping Address ───────────────────────────────────────────
# Shown to customers who select "I Will Supply Components" in the order form
NEXT_PUBLIC_SHIPPING_ADDRESS=No. XX, Your Street, Colombo XX, Sri Lanka.
